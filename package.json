{
  "name": "heat-tracker",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev": "corepack pnpm -r dev",
    "typecheck": "corepack pnpm -r typecheck",
    "lint": "corepack pnpm -r lint",
    "test": "corepack pnpm test:unit && corepack pnpm test:e2e",
    "test:unit": "corepack pnpm -r test",
    "test:coverage": "corepack pnpm -r test:coverage",
    "test:e2e": "corepack pnpm -C packages/heat-sdk build && corepack pnpm exec playwright test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@playwright/test": "^1.51.0",
    "better-sqlite3": "^11.5.0",
    "express": "^4.19.2",
    "tsup": "^8.3.6",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
